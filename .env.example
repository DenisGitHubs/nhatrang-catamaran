# ─────────────────────────────────────────────────────────────
# Шаблон переменных окружения. Скопируйте в .env.local и заполните.
# .env.local НЕ коммитится (см. .gitignore). Здесь только заглушки.
# ─────────────────────────────────────────────────────────────

# ---- Приложение (Vite, попадает в браузер — ТОЛЬКО публичные ключи!) ----
# Supabase: URL проекта и ПУБЛИЧНЫЙ anon-ключ (можно светить в фронте)
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...

# ---- Управление сервисами (CLI/MCP, НИКОГДА не в браузер) ----
# Supabase Personal Access Token (Account → Access Tokens)
SUPABASE_ACCESS_TOKEN=sbp_xxxxxxxxxxxxxxxx
# Ref проекта Supabase (в URL: xxxxxxxxxxxx из https://xxxxxxxxxxxx.supabase.co)
SUPABASE_PROJECT_REF=xxxxxxxxxxxx

# GitHub PAT для MCP-сервера (можно взять из `gh auth token`)
GITHUB_PERSONAL_ACCESS_TOKEN=gho_xxxxxxxxxxxx

# Telegram Bot Token (@BotFather → /token). СЕКРЕТ, только сервер/CLI.
TELEGRAM_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxx
